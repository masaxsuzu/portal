{
  "name": "portal",
  "license": "MIT",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:open": "jest --coverage && open coverage/lcov-report/index.html",
    "test:coverage:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "test:components": "jest --testPathPattern=components",
    "test:api": "jest --testPathPattern=api"
  },
  "dependencies": {
    "cookie": "^1.0.2",
    "next": "^16.1.4",
    "postcss": "^8.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.5",
    "@types/cookie": "^0.6.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "node-mocks-http": "^1.15.1",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.1.5",
    "ts-jest": "^29.4.4",
    "typescript": "^5"
  }
