{
  "name": "portal",
  "license": "MIT",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:open": "jest --coverage && open coverage/lcov-report/index.html",
    "test:coverage:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "test:components": "jest --testPathPattern=components",
    "test:api": "jest --testPathPattern=api",
    "ci": "npm run lint && npm run format:check && npm run test:coverage:ci && npm run build",
    "test:e2e": "playwright test",
    "pre-push": "npm run lint && npm run test:coverage:ci && npm run build && npm run format && npm run format:check",
    "prepare": "husky"
  },
  "dependencies": {
    "cookie": "^1.1.1",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.1.5",
    "@types/jest": "^30",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.1.5",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
